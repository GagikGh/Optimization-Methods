import math
import matplotlib.pyplot as plt
import numpy as np

def f(x):
    return x**2 - 4 * math.log(x) - 2

a = 0.5
b = 3
delta = 0.125

# --- Ընտրանքների եղանակ ---
x = a
min_x = x
min_f = f(x)

x_vals = []
y_vals = []

print(f"{'Քայլ': <5} | {'x': <10} | {'f(x)': <10}")
print("-" * 30)

step_count = 0
while x <= b:
    fx = f(x)
    x_vals.append(x)
    y_vals.append(fx)

    print(f"{step_count: <5} | {x: <10.4f} | {fx: <10.4f}")

    if fx < min_f:
        min_f = fx
        min_x = x

    x += delta
    step_count += 1

print("-" * 30)
print(f"Մինիմումը մոտավորապես գտնվում է x = {min_x}")
print(f"f(x) = {min_f}")

# --- Գրաֆիկ ---
x_plot = np.linspace(a, b, 400)
y_plot = x_plot**2 - 4 * np.log(x_plot) - 2  # updated here too

plt.figure(figsize=(10, 6))
plt.plot(x_plot, y_plot, label="f(x)", color='blue', alpha=0.5)
plt.scatter(x_vals, y_vals, color='red', s=20, label="Դիտարկված կետեր")
plt.scatter(min_x, min_f, color='green', s=100, label="Գտնված մինիմում", zorder=5)

plt.title("Մինիմումի որոնում քայլ առ քայլ")
plt.xlabel("x")
plt.ylabel("f(x)")
plt.legend()
plt.grid(True)
plt.show()
